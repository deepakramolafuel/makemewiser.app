# Make Me Wiser — environment variables
# Copy this file to .env.local and fill in real values. Do not commit .env.local.

# Supabase project URL (Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — server-only, keep secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key — server-only, used for submission moderation
ANTHROPIC_API_KEY=your-anthropic-api-key

# Optional override for the moderation model (defaults to claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# PostHog product analytics (optional — analytics no-ops until these are set)
# Project API key: PostHog → Settings → Project → "Project API Key" (starts with phc_).
# Safe to expose to the browser.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
# API host: https://us.i.posthog.com (US) or https://eu.i.posthog.com (EU)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# n8n lesson-intake webhook (server-only). Keep secret; do not hardcode in the repo.
N8N_WEBHOOK_URL=https://your-n8n-instance/webhook/your-path
# Optional shared secret if you enable Header Auth (header name: x-webhook-secret)
N8N_WEBHOOK_SECRET=
